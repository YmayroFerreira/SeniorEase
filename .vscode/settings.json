        {
           "regex": "^@angular",
           "orderLevel": 10,
           "numberOfEmptyLinesAfterGroup": 1
        },
        {
           "regex": "^rxjs",
           "orderLevel": 10,
           "numberOfEmptyLinesAfterGroup": 1
        },
        {
           "regex": "^@angular",
           "orderLevel": 20,
           "numberOfEmptyLinesAfterGroup": 1
        },
        {
           "regex": "^@root",
           "orderLevel": 30,
           "numberOfEmptyLinesAfterGroup": 1
        },
        {
           "regex": "^@core",
           "orderLevel": 40,
           "numberOfEmptyLinesAfterGroup": 1
        },
        {
           "regex": "^@layout",
           "orderLevel": 50,
           "numberOfEmptyLinesAfterGroup": 1
        },
        {
           "regex": "^@features",
           "orderLevel": 60,
           "numberOfEmptyLinesAfterGroup": 1
        },
        {
           "regex": "^@shared",
           "orderLevel": 70,
           "numberOfEmptyLinesAfterGroup": 1
